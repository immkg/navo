{
  "name": "navo",
  "version": "1.0.0",
  "description": "<p align=\"center\">   <img src=\"docs/navo-hero.png\" alt=\"Navo Hero\" width=\"100%\" /> </p>",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=api\" \"npm run dev --workspace=web\"",
    "lint": "npm run lint --workspace=api && npm run lint --workspace=web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspace=api && npm run test --workspace=web",
    "coverage": "npm run test:coverage --workspace=api && npm run test:coverage --workspace=web",
    "check": "npm run lint && npm run format:check && npm run test",
    "generate": "node tools/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/immkg/navo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/immkg/navo/issues"
  },
  "homepage": "https://github.com/immkg/navo#readme",
  "devDependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "concurrently": "^10.0.3",
    "ejs": "^6.0.1",
    "fs-extra": "^11.3.6",
    "ora": "^9.4.1",
    "prettier": "^3.9.4"
  }
}
